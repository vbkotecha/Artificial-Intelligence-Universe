# EditorConfig helps maintain consistent coding styles across editors and IDEs
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown: preserve trailing whitespace (2 spaces = hard line break)
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# YAML / JSON
[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

# Web
[*.{html,css,js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# Python
[*.py]
indent_style = space
indent_size = 4

# Shell
[*.{sh,bash}]
indent_style = space
indent_size = 4

# Ruby
[*.rb]
indent_style = space
indent_size = 2

# Windows scripts (keep CRLF)
[*.{bat,cmd,ps1}]
end_of_line = crlf
