# Auto-normalize line endings for all text files
* text=auto

# Explicitly enforce LF for these text formats
*.md      text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.ts      text eol=lf
*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.xml     text eol=lf
*.txt     text eol=lf
*.rb      text eol=lf
*.rake    text eol=lf
*.sh      text eol=lf
*.c       text eol=lf
*.cpp     text eol=lf
*.h       text eol=lf
*.hpp     text eol=lf
*.java    text eol=lf
*.scala   text eol=lf
*.kt      text eol=lf
*.go      text eol=lf
*.rs      text eol=lf
*.py      text eol=lf
*.php     text eol=lf
*.sql     text eol=lf
*.cfg     text eol=lf
*.ini     text eol=lf
*.toml    text eol=lf
*.csv     text eol=lf
*.tsv     text eol=lf
*.svg     text eol=lf
*.lock    text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Windows-specific: keep CRLF
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary files — do not touch
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.bmp     binary
*.tiff    binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.tar     binary
*.7z      binary
*.rar     binary
*.mp3     binary
*.mp4     binary
*.mov     binary
*.avi     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.otf     binary
*.exe     binary
*.dll     binary
*.so      binary
*.dylib   binary
